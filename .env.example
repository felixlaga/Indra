# Indra API and research providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

# Repository backend: memory for local experiments, postgres for durable use
INDRA_REPOSITORY_BACKEND=memory
INDRA_DATABASE_URL=postgresql://indra:indra@localhost:5432/indra

# Browser origins allowed to call the API
INDRA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local API protection. Leave blank for trusted local development.
INDRA_API_KEY=

# Optional paper-provider configuration
SEMANTIC_SCHOLAR_API_KEY=
HALUGATE_URL=http://localhost:8000
